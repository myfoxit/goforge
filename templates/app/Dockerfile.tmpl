# ---- build ----
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /out/app .

# ---- run ----
FROM alpine:3.20
RUN adduser -D -u 1000 app && apk add --no-cache ca-certificates tzdata
USER app
WORKDIR /home/app
COPY --from=build /out/app /usr/local/bin/app
EXPOSE 8090
VOLUME ["/home/app/forge_data"]
ENTRYPOINT ["app"]
CMD ["serve"]
