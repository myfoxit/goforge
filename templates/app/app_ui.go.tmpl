package main

import (
	"embed"
	"io/fs"
	"net/http"
	"strings"

	forge "github.com/myfoxit/goforge"
)

//go:embed all:ui/build
var uiFS embed.FS

// mountUI serves the compiled SvelteKit app at / (SPA fallback included).
// During development run `forge dev` instead — it serves the frontend from
// Vite with hot reload and proxies /api here.
func mountUI(app *forge.App) {
	sub, err := fs.Sub(uiFS, "ui/build")
	if err != nil {
		return
	}
	fileServer := http.FileServer(http.FS(sub))
	app.Mux().HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		path := strings.TrimPrefix(r.URL.Path, "/")
		if path == "" {
			path = "index.html"
		}
		if _, err := fs.Stat(sub, path); err != nil {
			path = "index.html" // SPA fallback
		}
		if strings.HasPrefix(path, "_app/") {
			w.Header().Set("Cache-Control", "public, max-age=31536000, immutable")
		}
		r2 := r.Clone(r.Context())
		r2.URL.Path = "/" + path
		fileServer.ServeHTTP(w, r2)
	})
}
