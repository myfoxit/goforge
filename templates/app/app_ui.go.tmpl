package main

import (
	"bytes"
	"embed"
	"io/fs"
	"mime"
	"net/http"
	"path"
	"strings"
	"time"

	forge "github.com/myfoxit/goforge"
)

//go:embed all:ui/build
var uiFS embed.FS

// mountUI serves the compiled SvelteKit app at / with SPA fallback.
// During development run `forge dev` instead — it serves the frontend from
// Vite with hot reload and proxies /api here.
func mountUI(app *forge.App) {
	sub, err := fs.Sub(uiFS, "ui/build")
	if err != nil {
		return
	}
	start := time.Now()
	app.Mux().HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
		name := strings.TrimPrefix(r.URL.Path, "/")
		if name == "" || strings.HasSuffix(name, "/") {
			name += "index.html"
		}
		name = strings.TrimPrefix(path.Clean("/"+name), "/")

		data, err := fs.ReadFile(sub, name)
		if err != nil {
			// SPA fallback for client-side routes.
			data, err = fs.ReadFile(sub, "index.html")
			if err != nil {
				http.NotFound(w, r)
				return
			}
			name = "index.html"
		}
		ctype := mime.TypeByExtension(path.Ext(name))
		if ctype == "" {
			ctype = "application/octet-stream"
		}
		w.Header().Set("Content-Type", ctype)
		if strings.HasPrefix(name, "_app/") {
			w.Header().Set("Cache-Control", "public, max-age=31536000, immutable")
		}
		http.ServeContent(w, r, name, start, bytes.NewReader(data))
	})
}
