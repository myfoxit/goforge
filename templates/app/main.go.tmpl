package main

import (
	forge "github.com/myfoxit/goforge"
	_ "github.com/myfoxit/goforge/pkg/db/drivers/{{.DB}}"

	_ "{{.Module}}/migrations"
)

func main() {
	app := forge.New()
	app.Use(forgeModules()...)
{{- if eq .Template "saas"}}
	app.Use(exampleModule{}) // seeds the demo "items" collection (see seed.go)
{{- end}}
{{- if .UI}}
	mountUI(app)
{{- end}}
	forge.Run(app)
}
